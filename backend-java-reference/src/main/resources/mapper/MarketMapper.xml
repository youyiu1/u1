<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neighborhood.app.mapper.MarketMapper">
    <resultMap id="BaseResultMap" type="com.neighborhood.app.entity.MarketItem">
        <id column="id" property="id"/>
        <result column="title" property="title"/>
        <result column="description" property="description"/>
        <result column="price" property="price"/>
        <result column="item_condition" property="itemCondition"/>
        <result column="images" property="images" typeHandler="com.neighborhood.app.handler.MySqlJsonTypeHandler"/>
        <result column="seller_id" property="sellerId"/>
        <result column="category" property="category"/>
        <result column="original_price" property="originalPrice"/>
        <result column="location" property="location"/>
        <result column="verified" property="verified"/>
        <result column="free_shipping" property="freeShipping"/>
    </resultMap>
</mapper>